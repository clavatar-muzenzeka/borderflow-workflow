flowchart LR

%% ==========================================
%% COULEURS
%% ==========================================

classDef actor fill:#0B5394,color:#fff,stroke:#073763,stroke-width:2px
classDef system fill:#D9EAF7,color:#000,stroke:#0B5394,stroke-width:2px
classDef process fill:#FFF2CC,color:#000,stroke:#BF9000,stroke-width:2px
classDef decision fill:#FCE5CD,color:#000,stroke:#B45F06,stroke-width:2px
classDef state fill:#EAD1DC,color:#000,stroke:#741B47,stroke-width:2px
classDef alert fill:#F4CCCC,color:#000,stroke:#990000,stroke-width:2px

%% ==========================================
%% ACTEURS
%% ==========================================

subgraph ACTEURS["ACTEURS EXTERNES ET INTERNES"]

F[Fournisseur Intrants]:::actor

T[Transporteur]:::actor

AM[Analyste Mails Caplaine]:::actor

AD[Analyste Dispatch Caplaine]:::actor

AG[Agent Douane / Terrain]:::actor

SUP[Superviseur Caplaine]:::actor

OPS[OPS KCC]:::actor

C1[Contrôleur C1]:::actor

C2[Contrôleur C2]:::actor

DIR[Directeur Opérations KCC]:::actor

CA[Clearing Agency]:::actor

DGDA[DGDA Audit]:::actor

end

%% ==========================================
%% SYSTEME
%% ==========================================

subgraph BORDERFLOW["BORDERFLOW"]

AI[Digestion IA + OCR]:::system

DOSSIER[Dossier documentaire numérique]:::system

TIMELINE[Historique / Audit Trail]:::system

TICKET[Ticket Overstanding]:::system

ALERTS[Moteur Alertes]:::system

end

%% ==========================================
%% ETAT INITIAL
%% ==========================================

START((Début)):::state

PREALERTE["Etat : Pré-alerte créée"]:::state

DISPATCHED["Etat : Dispatché"]:::state

BORDERIN["Etat : Border In"]:::state

DECLARATION["Etat : Déclaration douanière"]:::state

TRANSIT["Etat : KBP Out / Whisky In"]:::state

BORDEROUT["Etat : Border Out"]:::state

ARRIVAL["Etat : Arrivé Site KCC"]:::state

VALIDATED["Etat : Déclaration validée"]:::state

WAREHOUSE["Etat : Entreposé"]:::state

CLOSED((Dossier fermé)):::state

%% ==========================================
%% PHASE 1 - PREALERTE
%% ==========================================

START --> F

START --> T

F -->|Certificats qualité\nOrigine\nSanitaires| AM

T -->|Mail pré-alerte\nRM\nPO\nTT\nPlaques| AM

AM --> AI

AI --> D1{Mail analysable ?}:::decision

D1 -->|Oui| AUTO[Création automatique convoi]:::process

D1 -->|Non| MANUAL[Création manuelle convoi]:::process

AUTO --> DOSSIER
MANUAL --> DOSSIER

AUTO --> PREALERTE
MANUAL --> PREALERTE

DOSSIER -->|Ajout RM| DOSSIER
DOSSIER -->|Ajout TT| DOSSIER
DOSSIER -->|Ajout Certificats| DOSSIER

PREALERTE --> TIMELINE

%% ==========================================
%% PHASE 2 - DISPATCHING
%% ==========================================

PREALERTE --> AD

AD --> DISPATCH[Assignation Border Entry]:::process

AD --> ACCOUNT[Assignation Accountability]:::process

DISPATCH --> DISPATCHED
ACCOUNT --> DISPATCHED

DISPATCHED --> TIMELINE

%% ==========================================
%% PHASE 3 - BORDER IN
%% ==========================================

DISPATCHED --> AG

AG --> BI[Saisie Date Border In]:::process

AG --> ACA[Assignation Clearing Agency]:::process

BI --> BORDERIN
ACA --> BORDERIN

CA -->|Documents physiques| AG

BORDERIN --> TIMELINE

%% ==========================================
%% PROCESSUS PARALLELE OVERSTANDING
%% ==========================================

BORDERIN --> ALERTS

subgraph OVERSTANDING["SURVEILLANCE OVERSTANDING"]

ALERTS --> J2{>= J+2 ?}:::decision

J2 -->|Oui| CRIT[CRITICAL]:::alert

CRIT --> CA
CRIT --> ACCOUNTABLE[Responsable Accountability]:::actor

CRIT --> J5

J5{>= J+5 ?}:::decision

J5 -->|Oui| OVER[OVERSTANDING]:::alert

OVER --> DIR

OVER --> J10

J10{>= J+10 ?}:::decision

J10 -->|Oui| SMS[SMS Urgent]:::alert

SMS --> TICKET

SMS --> J15

J15{>= J+15 ?}:::decision

J15 -->|Oui| IMPACT[Rapport Impact Supply Chain]:::alert

IMPACT --> DIR

end

AG --> COMMENT[Commentaire blocage]:::process
COMMENT --> TICKET

SUP --> TICKET

TICKET --> RESOLU{Blocage résolu ?}:::decision

RESOLU -->|Non| TICKET

%% ==========================================
%% PHASE 4 DECLARATION DOUANIERE
%% ==========================================

BORDERIN --> DD

DD[Numéro déclaration\nRégime douanier\nLiquidation]:::process

DD --> DOSSIER

DD --> DECLARATION

DECLARATION --> TIMELINE

%% ==========================================
%% PHASE 5 TRANSIT
%% ==========================================

DECLARATION --> TRANSITPROC[KBP Out / Whisky In]:::process

TRANSITPROC --> TRANSIT

TRANSIT --> TIMELINE

%% ==========================================
%% PHASE 6 BORDER OUT
%% ==========================================

TRANSIT --> BO[Date Border Out]:::process

BO --> CALC[Calcul automatique délai]:::process

CALC --> FINALOVER[Calcul Overstanding définitif]:::process

FINALOVER --> BORDEROUT

BORDEROUT --> TIMELINE

BORDEROUT --> CLOSEOT[Clôture automatique Ticket]:::process

CLOSEOT --> TICKET

%% ==========================================
%% PHASE 7 ARRIVEE KCC
%% ==========================================

BORDEROUT --> OPS

OPS --> SCAN[Scan TT]:::process

OPS --> DRIVER[Identification conducteur]:::process

OPS --> FW[Assignation Final Warehouse]:::process

OPS --> CHECK[Checklist contrôle]:::process

OPS --> PHOTO[Upload Photos]:::process

SCAN --> ARRIVAL
DRIVER --> ARRIVAL
FW --> ARRIVAL
CHECK --> ARRIVAL
PHOTO --> ARRIVAL

ARRIVAL --> TIMELINE

%% ==========================================
%% PHASE 8 VALIDATION
%% ==========================================

ARRIVAL --> C1

C1 --> QC{Déclaration conforme ?}:::decision

QC -->|Oui| VALIDATED

QC -->|Non| NC[Commentaire obligatoire]:::process

NC --> C2

C2 --> CORRECTION[Analyse / Escalade]:::process

CORRECTION --> QC

VALIDATED --> TIMELINE

%% ==========================================
%% PHASE 9 ENTREPOSAGE
%% ==========================================

VALIDATED --> STORE[Assignation entrepôt final]:::process

STORE --> INVENT[Maj Inventaire]:::process

INVENT --> FICHE[Fiche entreposage]:::process

FICHE --> DOSSIER

FICHE --> WAREHOUSE

WAREHOUSE --> TIMELINE

%% ==========================================
%% FERMETURE
%% ==========================================

WAREHOUSE --> REVIEW[Revue finale dossier]:::process

REVIEW --> DOCS[Inspection documents]:::process

REVIEW --> IMGS[Inspection photos]:::process

REVIEW --> HISTORY[Consultation historique]:::process

DOCS --> CLOSEDEC{Dossier complet ?}:::decision
IMGS --> CLOSEDEC
HISTORY --> CLOSEDEC

CLOSEDEC -->|Non| C2

CLOSEDEC -->|Oui| CLOSEPROC[Validation fermeture]:::process

CLOSEPROC --> CLOSED

CLOSED --> TIMELINE

%% ==========================================
%% AUDIT DGDA
%% ==========================================

DGDA -. Consultation Historique .-> TIMELINE
DGDA -. Consultation Déclarations .-> DOSSIER

%% ==========================================
%% DASHBOARD DIRECTION
%% ==========================================

TIMELINE --> DASH[Reporting & Analytics]:::system

DASH --> DIR
